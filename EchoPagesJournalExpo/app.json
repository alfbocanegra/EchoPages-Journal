{
  "expo": {
    "name": "EchoPagesJournalExpo",
    "slug": "journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.EchoPagesJournalExpo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.EchoPagesJournalExpo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "echopagesjournal",
    "owner": "echopages",
    "plugins": [
      "expo-secure-store",
      "react-native-health-connect"
    ]
  }
}
