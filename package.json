    "nohoist": [
      "mobile/react-native",
      "mobile/react-native/**",
      "mobile/@react-native-community/cli-platform-ios",
      "mobile/@react-native-community/cli-platform-ios/**"
    ]
  },
  "scripts": {
    "build": "yarn workspaces run build",
